DATABASE_URL=postgresql://user:password@localhost:5432/maternaguard
SECRET_KEY=your-jwt-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DOCTOR_USERNAME=doctor
DOCTOR_PASSWORD=doctor123

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
DISTRICT_HOSPITAL_NUMBER=+91XXXXXXXXXX

# --- ML Inference ---
# For production: set this to your AWS Lambda function URL
# The backend will forward /predict requests to Lambda instead of loading models locally.
# LAMBDA_PREDICT_URL=https://xxxxxxxxxx.lambda-url.us-east-1.on.aws/

# For local dev: leave LAMBDA_PREDICT_URL unset and set these instead
MODEL_PATH=ml_new/models/model_rf_v1.pkl
SCALER_PATH=ml_new/models/scaler.pkl

# --- Frontend (Vite) ---
# Set in app/.env for the frontend
# VITE_API_BASE_URL=https://maternaguard-backend.onrender.com

ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
