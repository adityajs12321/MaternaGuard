{
  "name": "HealthLog",
  "type": "object",
  "properties": {
    "patient_email": {
      "type": "string",
      "description": "Email of the patient"
    },
    "log_date": {
      "type": "string",
      "format": "date-time"
    },
    "blood_pressure_systolic": {
      "type": "number"
    },
    "blood_pressure_diastolic": {
      "type": "number"
    },
    "heart_rate": {
      "type": "number"
    },
    "weight": {
      "type": "number"
    },
    "blood_glucose": {
      "type": "number"
    },
    "temperature": {
      "type": "number"
    },
    "oxygen_saturation": {
      "type": "number"
    },
    "symptoms": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of symptoms reported"
    },
    "symptom_severity": {
      "type": "string",
      "enum": [
        "mild",
        "moderate",
        "severe"
      ]
    },
    "notes": {
      "type": "string"
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "low"
    },
    "gestational_week": {
      "type": "number"
    }
  },
  "required": [
    "patient_email",
    "log_date"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.patient_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.patient_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.patient_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.patient_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}